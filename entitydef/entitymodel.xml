<entitymodel
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/entitymodel.xsd">
	<!-- ========================================================= -->
	<!-- ======================== Defaults ======================= -->
	<!-- ========================================================= -->
	<title>Entity of Sphinx Component</title>
	<description>None</description>
	<copyright></copyright>
	<version></version>

	<entity entity-name="topicMaster">
		<description>Entity for to Store the topic</description>
		<field name="topicId" type="id"></field>
		<field name="topicName" type="name"></field>
		<prim-key field="topicId" />
	</entity>

	<entity entity-name="questionMaster">
		<field name="questionId" type="numeric" />
		<field name="questionDetail" type="very-long" />
		<field name="optionA" type="very-long" />
		<field name="optionB" type="very-long" />
		<field name="optionC" type="very-long" />
		<field name="optionD" type="very-long" />
		<field name="answer" type="short-varchar" />
		<field name="numAnswers" type="numeric" />
		<field name="questionTypeId" type="short-varchar" />
		<field name="difficultyLevel" type="numeric" />
		<field name="answerValue" type="fixed-point" />
		<field name="topicId" type="id" />
		<field name="negativeMarkValue" type="fixed-point" />
		<prim-key field="questionId" />
		<relation type="one" rel-entity-name="topicMaster">
			<key-map field-name="topicId" />
		</relation>
		<relation type="one" rel-entity-name="Enumeration">
			<key-map field-name="questionTypeId" rel-field-name="enumId" />
		</relation>
	</entity>

	<entity entity-name="ExamMaster">
		<field name="examId" type="id"></field>
		<field name="examName" type="id"></field>
		<field name="description" type="description"></field>
		<field name="noOfQuestions" type="numeric" not-null="true"></field>
		<field name="duration" type="numeric" not-null="true"></field>
		<field name="passPercentage" type="numeric" not-null="true" />
		<field name="questionsRandomized" type="numeric"></field>
		<field name="answersMust" type="numeric"></field>
		<field name="allowNegativeMarks" type="numeric" />
		<field name="examSetupProper" type="numeric"></field>
		<field name="negativeMarkValue" type="currency-amount"></field>
		<field name="fromDate" type="date-time"></field>
		<field name="thruDate" type="date-time"></field>
		<!--field to store the adminId who created this exam -->
		<field name="createdByUserLogin" type="id-vlong"></field>
		<!--field to store the adminId who last modified this exam -->
		<field name="lastModifiedByUserLogin" type="id-vlong"></field>
		<prim-key field="examId" />
	</entity>


	<!-- ExamTopicMaster -->
	<entity entity-name="ExamTopicMapping">
		<field name="examId" type="id" not-null="true"></field>
		<field name="topicId" type="id" not-null="true"></field>
		<field name="percentage" type="floating-point" not-null="true"></field>
		<field name="topicPassPercentage" type="floating-point"
			not-null="true"></field>

		<prim-key field="topicId" />
		<prim-key field="examId" />

		<relation type="one" rel-entity-name="ExamMaster">
			<key-map field-name="examId"></key-map>
		</relation>

		<relation type="one" rel-entity-name="topicMaster">
			<key-map field-name="topicId" />
		</relation>
	</entity>

	
<!-- Exam Assignment Master -->
<!-- This is entity is used to store the how many exam assign to the user -->
<!-- <entity entity-name="ExamAssignMaster" package-name="">
	<field name="partyId" type="id"></field>
	<field name="examId" type="id"></field>
	<field name="examAssignId" type="id"></field>

	<prim-key field="examAssignId" />

	<relation type="one" rel-entity-name="ExamMaster">
		<key-map field-name="examId"></key-map>
	</relation>

	<relation type="one" rel-entity-name="UserLogin">
		<key-map field-name="partyId" />
	</relation>
</entity> -->


    <entity entity-name="PartyExamRelationship">
		<field name="partyId" type="id"></field>
		<field name="examId" type="id"></field>
		<field name="allowedAttempts" type="numeric" not-null="true"/>
		<field name="noOfAttempts" type="numeric" not-null="true"></field>
		<field name="lastPerformanceDate" type="date-time"></field>
		<field name="certificatePrinted" type="numeric"/>
		<field name="timeoutDays" type="numeric" not-null="true"></field>
		<field name="passwordChangesAuto" type="long-varchar"></field>
		<field name="canSplitExams" type="numeric"/>
		<field name="canSeeDetailedResults" type="numeric"></field>
		<field name="maxSplitAttempts" type="numeric"></field>
		<!-- A party can take the exam only within these stipulated dates -->
		<field name="fromDate" type="date-time"></field>
		<field name="thruDate" type="date-time"></field>
		<prim-key field="partyId" />
		<prim-key field="examId" />
		<relation rel-entity-name="Party" fk-name="USER_EXAM_UID_FK" type="many">
			<key-map field-name="partyId" rel-field-name="partyId" />
		</relation>	
		<relation rel-entity-name="ExamMaster" fk-name="USER_EXAM_EID_FK" type="many">
			<key-map field-name="examId" rel-field-name="examid" />
		</relation>			
    </entity>


	<!-- This entity is a question bank master -->
	<entity entity-name="QuestionBankMaster"
		package-name="in.vastpro.sphinx">
		<field name="examId" type="id"></field>
		<field name="questionId" type="numeric"></field>
		<field name="topicId" type="id" not-null="true" />
		<field name="questionDetail" type="very-long" not-null="true"></field>
		<field name="optiona" type="very-long" not-null="true"></field>
		<field name="optionb" type="very-long" not-null="true" />
		<field name="optionc" type="very-long" not-null="true"></field>
		<field name="optiond" type="very-long" not-null="true"></field>
		<field name="optione" type="very-long" not-null="true"></field>
		<field name="answer" type="short-varchar" not-null="true"></field>
		<field name="numAnswers" type="numeric" not-null="true" />
		<field name="questionTypeId" type="short-varchar"
			not-null="true"></field>
		<field name="difficultyLevel" type="numeric"></field>
		<field name="answerValue" type="fixed-point" />
		<field name="negativeMarkValue" type="fixed-point"></field>
		<prim-key field="examId" />
		<prim-key field="questionId" />
		<relation rel-entity-name="ExamMaster"
			fk-name="QUESTION_BANK_FK" type="many">
			<key-map field-name="examId" rel-field-name="examId" />
		</relation>
	</entity>


	<!-- First Questions are added/edited in this entity and when the exam setup 
		is invoked, the questions would be copied to the QuestionBankMaster -->
	<entity entity-name="QuestionBankMasterB"
		package-name="in.vastpro.sphinx">
		<field name="examId" type="id"></field>
		<field name="questionId" type="numeric"></field>
		<field name="topicId" type="id" not-null="true" />
		<field name="questionDetail" type="very-long" not-null="true"></field>
		<field name="optionA" type="very-long" ></field>
		<field name="optionB" type="very-long"  />
		<field name="optionC" type="very-long" ></field>
		<field name="optionD" type="very-long" ></field>
		<field name="answer" type="id" not-null="true"></field>
		<field name="numAnswers" type="numeric" not-null="true" />
		<field name="questionTypeId" type="short-varchar"
			not-null="true"></field>
		<field name="difficultyLevel" type="numeric"></field>
		<field name="answerValue" type="fixed-point" />
		<field name="negativeMarkValue" type="fixed-point"></field>
		<prim-key field="examId" />
		<prim-key field="questionId" />

		<relation rel-entity-name="ExamMaster"
			fk-name="QUESTION_BANK_B_FK" type="many">
			<key-map field-name="examId" rel-field-name="examId" />
		</relation>		
    </entity>
    
    
    	
	  <!-- This entity holds relationship between Admins and exams.
		Any admin listed here can manage the associated exam  -->
    <entity entity-name="AdminPartyExamRel" package-name="in.vastpro.sphinx">
		<field name="partyId" type="id"></field>
		<field name="examId" type="id"></field>
<!--Date threshold to control from when to when an Admin can manage the exam -->		
		<field name="fromDate" type="date-time"></field>
		<field name="thruDate" type="date-time"></field>
		<prim-key field="partyId" />
		<prim-key field="examId" />
		<relation rel-entity-name="Party" fk-name="USER_EXAM_UID_FK" type="many">
			<key-map field-name="partyId" rel-field-name="partyId" />
		</relation>	
		<relation rel-entity-name="ExamMaster" fk-name="USER_EXAM_EID_FK" type="many">
			<key-map field-name="examId" rel-field-name="examid" />
		</relation>			
    </entity>
    
    
      <!-- This entity has all the users who has not logged out -->
      <!-- This entity is used to  assign and store the data when the user will start the exam-->
    <entity entity-name="InProgressParty" package-name="in.vastpro.sphinx">
		<field name="partyId" type="id"></field>
		<field name="examId" type="id"></field>
		<field name="remainingTime" type="short-varchar"/>
		<field name="totalAnswered" type="numeric"></field>
		<field name="totalRemaining" type="numeric"></field>
		<field name="isExamActive" type="numeric" not-null="true"/>
		<field name="currentSplitAttempt" type="numeric"></field>
		<prim-key field="partyId" />
		<prim-key field="examId" />
		<relation rel-entity-name="Party" fk-name="INPROG_USERS_FK" type="many">
			<key-map field-name="partyId" rel-field-name="partyId" />
		</relation>				
    </entity>	
    
    
    <!-- to get the user -->
       <view-entity entity-name="PartyPersonalInfo" package-name="">
        <member-entity entity-alias="PY" entity-name="Party"/>
        <member-entity entity-alias="PN" entity-name="Person"/>
        <member-entity entity-alias="PR" entity-name="PartyRole"/>
        <member-entity entity-alias="UL" entity-name="UserLogin"/>
        
        
        <alias entity-alias="PR" name="roleTypeId"/>
        <alias entity-alias="PY" name="partyId"/>
        <alias entity-alias="PY" name="partyTypeId"/>
        <alias entity-alias="PY" name="statusId"/>
        <alias entity-alias="PN" name="firstName"/>
        <alias entity-alias="PN" name="lastName"/> 
        <alias entity-alias="UL" name="userLoginId"/> 
        
        <view-link entity-alias="PY" rel-entity-alias="PN">
            <key-map field-name="partyId"/>
        </view-link>
        
        <view-link entity-alias="PY" rel-entity-alias="PR">
            <key-map field-name="partyId"/>
        </view-link>
          <view-link entity-alias="PY" rel-entity-alias="UL">
            <key-map field-name="partyId"/>
        </view-link>
    </view-entity>
    
        <!-- Admin , Exam Join -->
       <view-entity entity-name="AdminExamRelationInfo" package-name="">
        <member-entity entity-alias="EM" entity-name="ExamMaster"/>
        <member-entity entity-alias="APER" entity-name="AdminPartyExamRel"/>
        
        
        <alias entity-alias="EM" name="examId"/>
        <alias entity-alias="EM" name="examName"/>
        <alias entity-alias="EM" name="description"/>
        <alias entity-alias="EM" name="noOfQuestions"/>
        <alias entity-alias="EM" name="duration"/>
        <alias entity-alias="EM" name="passPercentage"/> 
        <alias entity-alias="APER" name="partyId"/> 
        <view-link entity-alias="APER" rel-entity-alias="EM">
            <key-map field-name="examId"/>
        </view-link>
        
    </view-entity>
    
    <!-- exam and party Relationship -->
     <view-entity entity-name="ExamPartyRelationInfo" package-name="">
        <member-entity entity-alias="EM" entity-name="ExamMaster"/>
        <member-entity entity-alias="PER" entity-name="PartyExamRelationship"/>
        
        
        <alias entity-alias="EM" name="examId"/>
        <alias entity-alias="EM" name="examName"/>
        <alias entity-alias="EM" name="description"/>
        <alias entity-alias="EM" name="noOfQuestions"/>
        <alias entity-alias="EM" name="duration"/>
        <alias entity-alias="EM" name="passPercentage"/> 
        <alias entity-alias="PER" name="partyId"/>
       	<alias entity-alias="PER" name="timeoutDays"/> 
        <view-link entity-alias="PER" rel-entity-alias="EM">
            <key-map field-name="examId"/>
        </view-link>
        
    </view-entity>
    
    
    
    <!-- get the Exam assigned user -->
    <view-entity entity-name="ExamAssignedUser" package-name="">
        <member-entity entity-alias="PPI" entity-name="PartyPersonalInfo"/>
        <member-entity entity-alias="PER" entity-name="PartyExamRelationship"/>
        
        <alias entity-alias="PPI" name="userLoginId"/>
        <alias entity-alias="PPI" name="roleTypeId"/>
        <alias entity-alias="PPI" name="partyTypeId"/>
        <alias entity-alias="PPI" name="statusId"/>
        <alias entity-alias="PPI" name="firstName"/>
        <alias entity-alias="PPI" name="lastName"/>
        <alias entity-alias="PPI" name="partyId"/>
        <alias entity-alias="PER" name="allowedAttempts"/>
        <alias entity-alias="PER" name="timeoutDays"/>
        <alias entity-alias="PER" name="examId"/>
        
        <view-link entity-alias="PPI" rel-entity-alias="PER">
            <key-map field-name="partyId"/>
        </view-link>
    </view-entity>
    
    <!-- getting the unassigned user to the exam -->
<view-entity entity-name="ExamUnassignedUser" package-name="">
    <member-entity entity-alias="PPI" entity-name="PartyPersonalInfo"/>
    <member-entity entity-alias="PER" entity-name="PartyExamRelationship"/>

	<alias entity-alias="PPI" name="userLoginId"/>
    <alias entity-alias="PPI" name="partyId"/>
    <alias entity-alias="PPI" name="firstName"/>
    <alias entity-alias="PPI" name="lastName"/>
    <alias entity-alias="PPI" name="roleTypeId"/>
    <alias entity-alias="PPI" name="statusId"/>
    <alias entity-alias="PPI" name="partyTypeId"/>
    <alias entity-alias="PER" name="examId"/>
	<alias entity-alias="PPI" name="userLoginId"/>
	<alias entity-alias="PER" name="allowedAttempts"/>
    <alias entity-alias="PER" name="timeoutDays"/>
    <alias entity-alias="PER" field="partyId" name="examPartyId"/>

    <view-link entity-alias="PPI" rel-entity-alias="PER" rel-optional="true">
        <key-map field-name="partyId"/>
    </view-link>
</view-entity>


