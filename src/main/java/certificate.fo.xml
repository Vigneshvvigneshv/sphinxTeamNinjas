<?xml version="1.0" encoding="UTF-8"?>
<fo:root xmlns:fo="http://www.w3.org/1999/XSL/Format">

  <fo:layout-master-set>
    <fo:simple-page-master master-name="cert"
        page-width="297mm" page-height="210mm" margin="0mm">
      <fo:region-body margin="0mm"/>
    </fo:simple-page-master>
  </fo:layout-master-set>

  <fo:page-sequence master-reference="cert">
    <fo:flow flow-name="xsl-region-body">

      <!-- ══ BACKGROUND: cream ══ -->
      <fo:block-container position="absolute"
          top="0mm" left="0mm" width="297mm" height="210mm"
          background-color="#FDFAF2">
        <fo:block/>
      </fo:block-container>

      <!-- Parchment inner layer -->
      <fo:block-container position="absolute"
          top="12mm" left="12mm" width="273mm" height="186mm"
          background-color="#F5EDD8">
        <fo:block/>
      </fo:block-container>

      <!-- ══ BORDERS ══ -->
      <!-- Outer thick gold -->
      <fo:block-container position="absolute"
          top="7mm" left="7mm" width="283mm" height="196mm"
          border="3.5pt solid #8B6A14">
        <fo:block/>
      </fo:block-container>

      <!-- Mid gold -->
      <fo:block-container position="absolute"
          top="10mm" left="10mm" width="277mm" height="190mm"
          border="1.2pt solid #C8A84B">
        <fo:block/>
      </fo:block-container>

      <!-- Inner thin light gold -->
      <fo:block-container position="absolute"
          top="12mm" left="12mm" width="273mm" height="186mm"
          border="0.5pt solid #E8D080">
        <fo:block/>
      </fo:block-container>

      <!-- ══ CORNER ORNAMENTS (gold dots) ══ -->
      <!-- Top-left -->
      <fo:block-container position="absolute"
          top="15mm" left="15mm" width="6mm" height="6mm"
          background-color="#C8A84B">
        <fo:block font-family="serif" font-size="6pt"
                  color="#FDFAF2" text-align="center"
                  padding-top="0.8mm">●</fo:block>
      </fo:block-container>
      <!-- Top-right -->
      <fo:block-container position="absolute"
          top="15mm" left="276mm" width="6mm" height="6mm"
          background-color="#C8A84B">
        <fo:block font-family="serif" font-size="6pt"
                  color="#FDFAF2" text-align="center"
                  padding-top="0.8mm">●</fo:block>
      </fo:block-container>
      <!-- Bottom-left -->
      <fo:block-container position="absolute"
          top="189mm" left="15mm" width="6mm" height="6mm"
          background-color="#C8A84B">
        <fo:block font-family="serif" font-size="6pt"
                  color="#FDFAF2" text-align="center"
                  padding-top="0.8mm">●</fo:block>
      </fo:block-container>
      <!-- Bottom-right -->
      <fo:block-container position="absolute"
          top="189mm" left="276mm" width="6mm" height="6mm"
          background-color="#C8A84B">
        <fo:block font-family="serif" font-size="6pt"
                  color="#FDFAF2" text-align="center"
                  padding-top="0.8mm">●</fo:block>
      </fo:block-container>

      <!-- ══ TOP NAVY HEADER BAR ══ -->
      <fo:block-container position="absolute"
          top="13mm" left="13mm" width="271mm" height="22mm"
          background-color="#1C2B4A">
        <fo:block/>
      </fo:block-container>
      <!-- Gold line top of bar -->
      <fo:block-container position="absolute"
          top="13mm" left="13mm" width="271mm" height="0.8pt"
          background-color="#C8A84B">
        <fo:block/>
      </fo:block-container>
      <!-- Gold line bottom of bar -->
      <fo:block-container position="absolute"
          top="35mm" left="13mm" width="271mm" height="0.8pt"
          background-color="#C8A84B">
        <fo:block/>
      </fo:block-container>

      <!-- Platform name in header -->
      <fo:block-container position="absolute"
          top="20mm" left="13mm" width="271mm">
        <fo:block font-family="serif" font-size="8pt"
                  color="#E8D080" text-align="center"
                  letter-spacing="5pt">SPHINX ASSESSMENT PLATFORM</fo:block>
      </fo:block-container>

      <!-- ══ CERTIFICATE TITLE ══ -->
      <fo:block-container position="absolute"
          top="37mm" left="13mm" width="271mm">
        <fo:block font-family="serif" font-size="46pt"
                  color="#1C2B4A" text-align="center"
                  font-style="italic" font-weight="bold">Certificate</fo:block>
      </fo:block-container>

      <!-- OF ACHIEVEMENT -->
      <fo:block-container position="absolute"
          top="73mm" left="13mm" width="271mm">
        <fo:block font-family="serif" font-size="9pt"
                  color="#C8A84B" text-align="center"
                  letter-spacing="8pt">OF ACHIEVEMENT</fo:block>
      </fo:block-container>

      <!-- Gold rule top -->
      <fo:block-container position="absolute"
          top="80mm" left="88mm" width="121mm" height="1pt"
          background-color="#C8A84B">
        <fo:block/>
      </fo:block-container>
      <fo:block-container position="absolute"
          top="81.5mm" left="88mm" width="121mm" height="0.4pt"
          background-color="#E8D080">
        <fo:block/>
      </fo:block-container>

      <!-- THIS IS TO CERTIFY THAT -->
      <fo:block-container position="absolute"
          top="84mm" left="13mm" width="271mm">
        <fo:block font-family="serif" font-size="8pt"
                  color="#7A8899" text-align="center"
                  letter-spacing="4pt">THIS IS TO CERTIFY THAT</fo:block>
      </fo:block-container>

      <!-- ══ CANDIDATE NAME ══ -->
      <fo:block-container position="absolute"
          top="91mm" left="13mm" width="271mm">
        <fo:block font-family="serif" font-size="32pt"
                  color="#1C2B4A" text-align="center"
                  font-style="italic" font-weight="bold">${candidateName}</fo:block>
      </fo:block-container>

      <!-- Name underline thick -->
      <fo:block-container position="absolute"
          top="107mm" left="73mm" width="151mm" height="1pt"
          background-color="#C8A84B">
        <fo:block/>
      </fo:block-container>
      <!-- Name underline thin -->
      <fo:block-container position="absolute"
          top="108.5mm" left="73mm" width="151mm" height="0.4pt"
          background-color="#E8D080">
        <fo:block/>
      </fo:block-container>

      <!-- Body text -->
      <fo:block-container position="absolute"
          top="111mm" left="50mm" width="197mm">
        <fo:block font-family="serif" font-size="9.5pt"
                  color="#7A8899" text-align="center">
          has successfully completed the examination and demonstrated outstanding proficiency.
        </fo:block>
      </fo:block-container>

      <!-- ══ SCORE BOX ══ -->
      <!-- Shadow -->
      <fo:block-container position="absolute"
          top="120.5mm" left="76.5mm" width="44mm" height="20mm"
          background-color="#D4C090">
        <fo:block/>
      </fo:block-container>
      <!-- Fill -->
      <fo:block-container position="absolute"
          top="120mm" left="76mm" width="44mm" height="20mm"
          background-color="#FBF5E6"
          border="1.2pt solid #C8A84B">
        <fo:block font-family="serif" font-size="6.5pt"
                  color="#7A8899" text-align="center"
                  letter-spacing="2pt" padding-top="3mm">SCORE</fo:block>
        <fo:block font-family="serif" font-size="20pt"
                  color="#8B6A14" text-align="center"
                  font-weight="bold">${score}%</fo:block>
      </fo:block-container>

      <!-- ══ STATUS BOX ══ -->
      <!-- Shadow -->
      <fo:block-container position="absolute"
          top="120.5mm" left="126.5mm" width="44mm" height="20mm"
          background-color="#D4C090">
        <fo:block/>
      </fo:block-container>
      <!-- Fill -->
      <fo:block-container position="absolute"
          top="120mm" left="126mm" width="44mm" height="20mm"
          background-color="#FBF5E6"
          border="1.2pt solid #1E8449">
        <fo:block font-family="serif" font-size="6.5pt"
                  color="#7A8899" text-align="center"
                  letter-spacing="2pt" padding-top="3mm">STATUS</fo:block>
        <fo:block font-family="serif" font-size="16pt"
                  color="#1E8449" text-align="center"
                  font-weight="bold">${status}</fo:block>
      </fo:block-container>

      <!-- ══ DATE BOX ══ -->
      <!-- Shadow -->
      <fo:block-container position="absolute"
          top="120.5mm" left="176.5mm" width="44mm" height="20mm"
          background-color="#D4C090">
        <fo:block/>
      </fo:block-container>
      <!-- Fill -->
      <fo:block-container position="absolute"
          top="120mm" left="176mm" width="44mm" height="20mm"
          background-color="#FBF5E6"
          border="1.2pt solid #C8A84B">
        <fo:block font-family="serif" font-size="6.5pt"
                  color="#7A8899" text-align="center"
                  letter-spacing="2pt" padding-top="3mm">DATE</fo:block>
        <fo:block font-family="serif" font-size="10pt"
                  color="#1C2B4A" text-align="center"
                  font-weight="bold" padding-top="1mm">${date}</fo:block>
      </fo:block-container>

      <!-- ══ SECTION DIVIDER ══ -->
      <fo:block-container position="absolute"
          top="145mm" left="20mm" width="257mm" height="1pt"
          background-color="#C8A84B">
        <fo:block/>
      </fo:block-container>
      <fo:block-container position="absolute"
          top="146.5mm" left="20mm" width="257mm" height="0.4pt"
          background-color="#E8D080">
        <fo:block/>
      </fo:block-container>

      <!-- ══ SEAL ══ -->
      <fo:block-container position="absolute"
          top="150mm" left="108mm" width="28mm" height="28mm"
          background-color="#1C2B4A"
          border="2pt solid #C8A84B">
        <fo:block font-family="serif" font-size="8pt"
                  color="#E8D080" text-align="center"
                  font-weight="bold" padding-top="7mm"
                  letter-spacing="1pt">SPHINX</fo:block>
        <fo:block font-family="serif" font-size="6pt"
                  color="#C8A84B" text-align="center"
                  letter-spacing="1pt">VERIFIED</fo:block>
        <fo:block font-family="serif" font-size="12pt"
                  color="#C8A84B" text-align="center">✦</fo:block>
      </fo:block-container>

      <!-- ══ DIRECTOR SIGNATURE ══ -->
      <!-- Signature line -->
      <fo:block-container position="absolute"
          top="158mm" left="185mm" width="82mm" height="0.6pt"
          background-color="#9AAABB">
        <fo:block/>
      </fo:block-container>

      <!-- Director name (italic, looks like signature) -->
      <fo:block-container position="absolute"
          top="160mm" left="185mm" width="82mm">
        <fo:block font-family="serif" font-size="13pt"
                  color="#1C2B4A" text-align="center"
                  font-style="italic">${directorName}</fo:block>
        <fo:block font-family="serif" font-size="6.5pt"
                  color="#7A8899" text-align="center"
                  letter-spacing="2pt" padding-top="1.5mm">DIRECTOR OF PROGRAMS</fo:block>
        <fo:block font-family="serif" font-size="6pt"
                  color="#AABBCC" text-align="center"
                  letter-spacing="1pt" padding-top="1mm">SPHINX ASSESSMENT PLATFORM</fo:block>
      </fo:block-container>

      <!-- ══ BOTTOM NAVY FOOTER ══ -->
      <fo:block-container position="absolute"
          top="192mm" left="13mm" width="271mm" height="5mm"
          background-color="#1C2B4A">
        <fo:block/>
      </fo:block-container>
      <fo:block-container position="absolute"
          top="192mm" left="13mm" width="271mm" height="0.8pt"
          background-color="#C8A84B">
        <fo:block/>
      </fo:block-container>
      <fo:block-container position="absolute"
          top="193.5mm" left="13mm" width="271mm">
        <fo:block font-family="serif" font-size="6.5pt"
                  color="#E8D080" text-align="center"
                  letter-spacing="1.5pt">This certificate is issued by Sphinx Assessment Platform   |   Date of Issue: ${date}</fo:block>
      </fo:block-container>

      <fo:block/>
    </fo:flow>
  </fo:page-sequence>
</fo:root>