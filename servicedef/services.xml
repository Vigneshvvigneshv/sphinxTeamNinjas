		engine="entity-auto" invoke="delete" default-entity-name="ExamTopicMapping"> 
		<auto-attributes include="pk" mode="IN" optional="true"/> </service> -->

	<!-- generating question by topic percentage -->
	<service name="generateQuestionsService" engine="java"
		location="com.vastpro.sphinx.services.GenerateQuestionsMasterBService"
		invoke="generateQuestionsService">
		<attribute name="examId" mode="IN" type="String" />
		<attribute name="TopicList" mode="IN" type="List" />
	</service>


	<service name="addQuestionInMasterB" engine="entity-auto"
		invoke="create" default-entity-name="QuestionBankMasterB">
