<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/services.xsd">
	<description>Sphinx Services</description>
	<vendor></vendor>
	<version>1.0</version>

	<service name="noSyntaxError" engine="interface">
		<description>
            Dummy service to prevent empty files and syntax error - Remove when the 1st real service will be added here 
        </description>
	</service>
	
	<!-- UserLogin Service -->

	<service name="validateUserLoginService" engine="java"
		location="com.vastpro.sphinx.services.UserLoginService"
		invoke="validateUserLoginService">
		<attribute name="userName" mode="IN" type="String"></attribute>
		<attribute name="password" mode="IN" type="String"></attribute>
		<attribute name="role" mode="OUT" type="String"></attribute>
		<attribute name="userName" mode="OUT" type="String"
			optional="true"></attribute>
		<attribute name="password" mode="OUT" type="String"
			optional="true"></attribute>
	</service>
	
	<!-- End of UserLogin Service -->

	<!-- UserSignUP Service -->

	<service name="userSignUpServiceOwn" engine="java"
		location="com.vastpro.sphinx.services.UserSignUpService"
		invoke="signUpService">

		<attribute name="userName" mode="IN" type="String"></attribute>
		<attribute name="password" mode="IN" type="String"></attribute>
		<attribute name="firstName" mode="IN" type="String"></attribute>
		<attribute name="lastName" mode="IN" type="String"></attribute>
		<attribute name="email" mode="IN" type="String"></attribute>
	</service>

<!-- <service name="userSignUpService" engine="entity-auto"
		invoke="create" default-entity-name="">

		<attribute name="userName" mode="IN" type="String"></attribute>
		<attribute name="password" mode="IN" type="String"></attribute>
		<attribute name="firstName" mode="IN" type="String"></attribute>
		<attribute name="lastName" mode="IN" type="String"></attribute>
		<attribute name="email" mode="IN" type="String"></attribute>
	</service> -->
	
<!-- End of UserSignUP Service -->


	<!-- topic Service start-->
	
	<!-- create topic -->
	<service name="createTopicOwn" engine="java"
		location="com.vastpro.sphinx.services.TopicService"
		invoke="createTopic">
		<attribute name="topicName" mode="IN" type="String"></attribute>
	</service>
	
	<!-- update topic -->
	<service name="updateTopicOwn" engine="java"
		location="com.vastpro.sphinx.services.TopicService"
		invoke="updateTopic">
		<attribute name="topicId" mode="IN" type="String"></attribute>
		<attribute name="topicName" mode="IN" type="String"></attribute>
	</service>
	
	<!-- delete topic -->
	<service name="deleteTopicOwn" engine="java"
		location="com.vastpro.sphinx.services.TopicService"
		invoke="deleteTopic">
		<attribute name="topicId" mode="IN" type="String"></attribute>
	</service>
	
	<!-- get all topic list -->
	<service name="getAllTopics" engine="java"
		location="com.vastpro.sphinx.services.TopicService"
		invoke="getAllTopics">
		<attribute name="topicList" mode="OUT" type="List"></attribute>
	</service>
	
	
	<service  name="createTopic" engine="entity-auto" invoke="create" default-entity-name="topicMaster">
		<auto-attributes include="pk" mode="OUT" optional="false"/>
        <auto-attributes include="nonpk" mode="IN" optional="false"/>
	</service>
	
	<service  name="updateTopic" engine="entity-auto" invoke="update" default-entity-name="topicMaster">
		<attribute name="topicId" mode="IN" type="String"></attribute>
		<attribute name="topicName" mode="IN" type="String"></attribute>
	</service>
	
	<service  name="deleteTopic" engine="entity-auto" invoke="delete" default-entity-name="topicMaster">
		<attribute name="topicId" mode="IN" type="String"></attribute>
	</service>
	<!-- end of topic service -->


<!-- Start of Exam Service -->

	<!-- Create Exam -->
	<service engine="java" name="createExamOwn" location="com.vastpro.sphinx.service.ExamService" invoke="createExam">
		<attribute name="examName" mode="IN" type="String"></attribute>
		<attribute name="description" mode="IN" type="String"></attribute>
		<attribute name="noOfQuestions" mode="IN" type="String"></attribute>
		<attribute name="duration" mode="IN" type="String"></attribute>
		<attribute name="passPercentage" mode="IN" type="String"></attribute>
	</service>


<service engine="entity-outo" name="createExam" invoke="create" default-entity-name="examMaster">
	<auto-attributes mode="IN" include="pk" optional="false"></auto-attributes>
	<auto-attributes mode="IN" include="nonpk" optional="true"></auto-attributes>
</service>
<!-- End of Exam Service  -->


<!--  -->
	<service name="createQuestionService" engine="java"
		location="com.vastpro.sphinx.services.QuestionService"
		invoke="createQuestionService">
		<attribute name="questionDetail" mode="IN" type="String"></attribute>
		<attribute name="optionA" mode="IN" type="String"
			optional="false" />
		<attribute name="optionB" mode="IN" type="String"
			optional="false" />
		<attribute name="optionC" mode="IN" type="String"
			optional="false" />
		<attribute name="optionD" mode="IN" type="String"
			optional="false" />
		<attribute name="optionE" mode="IN" type="String"
			optional="true" />
		<attribute name="answer" mode="IN" type="String"
			optional="false" />
		<attribute name="numAnswers" mode="IN" type="Long"
			optional="false" />
		<attribute name="questionTypeId" mode="IN" type="String"
			optional="false" />
		<attribute name="difficultyLevel" mode="IN" type="Long"
			optional="true" />
		<attribute name="answerValue" mode="IN" type="BigDecimal"
			optional="true" />
		<attribute name="topicId" mode="IN" type="String"
			optional="false" />
		<attribute name="negativeMarkValue" mode="IN"
			type="BigDecimal" optional="true" />

		<attribute name="questionId" mode="OUT" type="Long"
			optional="false"></attribute>
	</service>


<service  name="createQuestion" engine="entity-auto" invoke="create" default-entity-name="questionMaster">
		<auto-attributes include="pk" mode="OUT" optional="false"/>
        <auto-attributes include="nonpk" mode="IN" optional="false"/>
	</service>



<!-- UpdateQuestions Service -->
	<service name="updateQuestionMaster" engine="java"
         location="com.vastpro.sphinx.services.QuestionService"
         invoke="updateQuestion">
    <description>Update an existing question in QuestionMaster</description>
    <attribute name="questionId"        type="Long"     mode="IN"  optional="false"/> 
    <attribute name="questionDetail"    type="String"     mode="IN"  optional="true"/>
    <attribute name="optionA"           type="String"     mode="IN"  optional="true"/>
    <attribute name="optionB"           type="String"     mode="IN"  optional="true"/>
    <attribute name="optionC"           type="String"     mode="IN"  optional="true"/>
    <attribute name="optionD"           type="String"     mode="IN"  optional="true"/>
    <attribute name="optionE"           type="String"     mode="IN"  optional="true"/>
    <attribute name="answer"            type="String"     mode="IN"  optional="true"/>
    <attribute name="numAnswers"        type="Long"       mode="IN"  optional="true"/>
    <attribute name="questionTypeId"    type="String"     mode="IN"  optional="true"/>
    <attribute name="difficultyLevel"   type="Long"       mode="IN"  optional="true"/>
    <attribute name="answerValue"       type="BigDecimal" mode="IN"  optional="true"/>
    <attribute name="topicId"           type="String"     mode="IN"  optional="true"/>
    <attribute name="negativeMarkValue" type="BigDecimal" mode="IN"  optional="true"/>
   
    <attribute name="questionId"        type="Long"     mode="OUT" optional="false"/>
</service>

<!-- DeleteQuestion Service -->
	<service name="deleteQuestionMaster" engine="java" location="com.vastpro.sphinx.services.QuestionService" invoke="deleteQuestion">
		<attribute name="questionId" type="Long" mode="IN" optional="false"/>
    	<attribute name="message"    type="String" mode="OUT" optional="false"/>
	</service>
	
	<service name="deleteQuestion" engine="entity-auto" invoke="delete" default-entity-name="questionMaster">
		<auto-attributes include="pk" mode="IN" optional="false"/>
	</service>
	
	
	<!-- GetQuestionsBY Topic -->
	
	<service name="getQuestionsByTopic" engine="java" location="com.vastpro.sphinx.services.QuestionService" invoke="getQuestionsByTopic">
		<attribute name="topicId" mode="IN" type="String" optional="false"/>
		<attribute name="topicName" type="String" mode="OUT" optional="false"/>
		<attribute name="totalCount" type="Integer" mode="OUT" optional="false"/>
		<attribute name="questionList" mode="OUT" type="List"/>
		<attribute name="topicId" mode="OUT" type="String" optional="false"/>
	</service>
	
</services>